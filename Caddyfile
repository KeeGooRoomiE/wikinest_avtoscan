# Reverse proxy + static file server for the VM-hosted wiki.
#
# INTERIM STATE (see DEPLOYMENT.md "Порт вместо домена"): this VM sits behind
# the provider's shared IP — standard external 80/443 belong to someone else
# on that IP (their own nginx answers there), we only get the NAT-forwarded
# high ports (26500->80, 26502->443 internally). That means Caddy can't do
# ACME/Let's Encrypt here (HTTP-01 needs real port 80 reachable at the domain)
# — hence `tls internal` (self-signed, browser will warn once) instead of
# `{$DOMAIN}` with automatic HTTPS. Revisit if a dedicated IP or a tunnel
# (Cloudflare Tunnel etc.) ever replaces this. Plain :80 deliberately isn't
# served at all — a Secure-flagged session cookie won't attach over it, so
# leaving it up just means login silently fails there instead of prompting
# people to the working https:// port.
:443 {
	# `:443` has no hostname to key off of, so tls internal alone won't issue
	# anything — Caddy looks for a cert matching the ClientHello's SNI, finds
	# none, and refuses ("no certificate matching TLS ClientHello", verified
	# via `debug` global option + tls.handshake logs). on_demand tells it to
	# self-sign one for whatever SNI shows up instead of requiring the
	# hostname be known up front.
	tls internal {
		on_demand
	}

	encode gzip

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
	}

	handle /api/* {
		reverse_proxy backend:8000
	}

	handle {
		root * /srv/static
		# SPA routing: any path with no matching static file falls back to
		# docs.html, which reads location.pathname itself (see docs.html init()).
		try_files {path} /docs.html
		file_server
	}
}
